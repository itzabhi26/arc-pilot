# WalletConnect v2 project id — get a free one at https://dashboard.reown.com
# Required only for the "WalletConnect" connect option; MetaMask/Rabby/OKX
# work without it via direct browser-extension injection.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Address of the SmartWalletFactory contract (contracts/SmartWalletFactory.sol)
# deployed on Arc Testnet. Deploy it once with:
#   node scripts/deploy-smart-wallet-factory.mjs
# and paste the resulting address here. Until this is set, ARC Pilot falls
# back to its previous behavior (the connected signer's own address is used
# as the dashboard address) so the app keeps working without it.
NEXT_PUBLIC_SMART_WALLET_FACTORY_ADDRESS=
